<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('partials/head') %>
        <title>whyCinema - Phim chiếu rạp</title>
        <link rel="stylesheet" href="/css/home.css">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-white text-dark">
    <%- include('partials/header') %>

        <div class="hero-section mb-5" style="background-color: #fde7f3; padding: 50px 0;">
            <div class="container">
                <div class="row align-items-center g-4">
                    <div class="col-md-6 hero-content">
                        <h1 class="display-5 fw-bold mb-3" style="color: #a50064;">Phim chiếu rạp 2026</h1>
                        <p class="fs-5 text-secondary mb-4">Danh sách Phim Chiếu Rạp đặc sắc và đáng mong đợi nhất</p>

                        <ul class="list-unstyled fw-medium text-dark">
                            <li class="mb-3 d-flex align-items-center gap-2">
                                <i class="bi bi-check text-danger bg-danger bg-opacity-10 rounded-circle p-1"></i>
                                Đa dạng <strong>phim chiếu rạp 2026</strong>
                            </li>
                            <li class="mb-3 d-flex align-items-center gap-2">
                                <i class="bi bi-check text-danger bg-danger bg-opacity-10 rounded-circle p-1"></i>
                                Lịch chiếu phim <strong>cập nhật đầy đủ nhất</strong>
                            </li>
                            <li class="mb-3 d-flex align-items-center gap-2">
                                <i class="bi bi-check text-danger bg-danger bg-opacity-10 rounded-circle p-1"></i>
                                <strong>Đánh giá phim rạp</strong> chi tiết chân thật
                            </li>
                            <li class="mb-3 d-flex align-items-center gap-2">
                                <i class="bi bi-check text-danger bg-danger bg-opacity-10 rounded-circle p-1"></i>
                                Đặt vé <strong>xem phim Online</strong> dễ dàng
                            </li>
                        </ul>
                    </div>
                    <div class="col-md-6 text-center text-md-end">
                        <img src="https://homepage.momocdn.net/img/momo-amazone-s3-api-241016111327-638646740077856660.jpg"
                            class="img-fluid rounded-4 shadow-lg" alt="MoMo Banner"
                            style="max-height: 380px; object-fit: cover;">
                    </div>
                </div>
            </div>
        </div>

        <div class="now-showing-section py-5 mb-5" style="background-color: #141414;">
            <div class="container">
                <div class="section-header d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h2 class="text-white fw-bold mb-0 title-border">PHIM ĐANG CHIẾU</h2>
                        <p class="text-white-50 small mb-0 mt-1">Khám phá những siêu phẩm điện ảnh mới nhất</p>
                    </div>
                    <a href="/tat-ca-phim" class="text-danger text-decoration-none fw-bold small">
                        Xem tất cả <i class="bi bi-chevron-right"></i>
                    </a>
                </div>

                <div class="d-flex flex-nowrap overflow-auto gap-3 pb-3 custom-scrollbar">
                    <% heroMovies.forEach((movie)=> { %>
                        <div class="movie-card flex-shrink-0" style="width: 230px; margin-right: 15px;">
                            <div class="movie-poster-wrapper position-relative rounded-3 overflow-hidden shadow-sm"
                                style="cursor: pointer;" data-id="<%= movie._id %>" data-title="<%= movie.tenPhim %>"
                                data-poster="<%= movie.hinhAnhNen %>" data-desc="<%= movie.noiDungPhim %>"
                                data-trailer="<%= movie.duongDanTrailer %>" onclick="openTrailerModal(this)">

                                <span class="badge bg-danger position-absolute top-0 start-0 m-2 z-2">
                                    <%= movie.gioiHanTuoi %>+
                                </span>

                                <img src="<%= movie.hinhAnhNen || movie.hinhAnhPoster %>" class="w-100"
                                    style="height: 340px; object-fit: cover; display: block;"
                                    alt="<%= movie.tenPhim %>">
                                <div
                                    class="movie-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                                    <i class="bi bi-play-circle text-white shadow-sm" style="font-size: 3.5rem;"></i>
                                </div>
                            </div>

                            <div class="movie-info mt-3 text-start" style="cursor: pointer;"
                                onclick="window.location.href='/chitietphim?id=<%= movie._id %>'">
                                <h3 class="fs-6 fw-bold text-white text-truncate mb-1">
                                    <%= movie.tenPhim %>
                                </h3>
                                <p class="text-white-50 small mb-1 text-truncate">
                                    <%= movie.noiDungPhim %>
                                </p>
                                <p class="text-warning small mb-0"><i class="bi bi-star-fill"></i> 9.0</p>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>
        </div>

        <div class="container mb-5">
            <h2 class="title-border fw-bold mb-4 fs-3" style="color: #a50064;">Tìm phim chiếu rạp trên MoMo</h2>

            <div class="filter-wrapper shadow-sm rounded-4 border bg-white p-3 mb-4">
                <div class="row align-items-center g-3">
                    <div class="col-md-5">
                        <div class="search-input-group d-flex align-items-center bg-light rounded-3 px-3 border">
                            <i class="bi bi-search text-secondary"></i>
                            <input type="text" id="movie-search"
                                class="form-control border-0 bg-transparent shadow-none"
                                placeholder="Tìm kiếm phim, rạp chiếu...">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select select-custom bg-light border-0">
                            <option selected>Tất cả khu vực</option>
                            <option>An Giang</option>
                            <option>Long Xuyên</option>
                        </select>
                    </div>
                    <div class="col-md-4 text-end">
                        <div class="col-md-4 text-end">
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="btnradio" id="btnradio1" value="dang-chieu"
                                    checked>
                                <label class="btn btn-outline-danger rounded-start-pill fw-medium" for="btnradio1">Đang
                                    chiếu</label>

                                <input type="radio" class="btn-check" name="btnradio" id="btnradio2" value="sap-chieu">
                                <label class="btn btn-outline-danger rounded-end-pill fw-medium" for="btnradio2">Sắp
                                    chiếu</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="movie-grid" class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-4 mb-5">
                <div class="col-12 text-center py-5">
                    <div class="spinner-border text-danger" role="status"></div>
                    <p class="mt-2 text-muted">Đang tải danh sách phim...</p>
                </div>
            </div>
        </div>

        <div class="modal fade" id="trailerModal" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg overflow-hidden"
                    style="background-color: #1a1a1a; border-radius: 12px;">

                    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3 z-3"
                        data-bs-dismiss="modal" aria-label="Close"
                        style="background-color: rgba(0,0,0,0.5); border-radius: 50%; padding: 10px;"></button>

                    <div class="ratio ratio-16x9 bg-black">
                        <iframe id="trailer-iframe" src="" title="Trailer" allowfullscreen allow="autoplay"></iframe>
                    </div>

                    <div class="modal-body p-4 text-white">
                        <div class="d-flex gap-3">
                            <img id="trailer-poster" src="" alt="Poster" class="rounded-3 shadow"
                                style="width: 110px; height: 160px; object-fit: cover;">

                            <div class="d-flex flex-column justify-content-between w-100">
                                <div>
                                    <h4 id="trailer-title" class="fw-bold mb-1">Tên Phim</h4>
                                    <p class="text-secondary small mb-2">Đang chiếu</p>
                                    <p id="trailer-desc" class="small text-light opacity-75 mb-3"
                                        style="display: -webkit-box; -webkit-line-clamp: 3;line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                        Nội dung phim...
                                    </p>
                                </div>

                                <div class="d-flex gap-2">
                                    <a id="trailer-book-btn" href="#" class="btn px-4 fw-bold rounded-3"
                                        style="background-color: var(--momo-pink); color: white;">Đặt vé</a>
                                    <button type="button" class="btn btn-secondary px-4 fw-bold rounded-3"
                                        data-bs-dismiss="modal"
                                        style="background-color: #6c757d; border: none;">Đóng</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script src="/js/app.js?v=999"></script>
</body>

</html>