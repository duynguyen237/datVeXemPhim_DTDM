<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('../partials/head') %>
        <title>Thống Kê Doanh Thu - Admin</title>
        <link rel="stylesheet" href="/css/admin_dashboard.css">
        <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="bg-light">
    <%- include('../partials/admin_sidebar') %>
        <div class="container py-5">
            <h2 class="mb-4 text-primary"><i class="bi bi-graph-up-arrow"></i> Báo Cáo Doanh Thu</h2>

            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card bg-success text-white shadow-sm">
                        <div class="card-body">
                            <h5>Tổng Doanh Thu</h5>
                            <h3 class="fw-bold">
                                <%= tongQuan.TongDoanhThu.toLocaleString('vi-VN') %> VNĐ
                            </h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-primary text-white shadow-sm">
                        <div class="card-body">
                            <h5>Doanh Thu Hôm Nay</h5>
                            <h3 class="fw-bold">
                                <%= tongQuan.DoanhThuHnay.toLocaleString('vi-VN') %> VNĐ
                            </h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-info text-white shadow-sm">
                        <div class="card-body">
                            <h5>Tổng Số Vé Đã Bán</h5>
                            <h3 class="fw-bold">
                                <%= tongQuan.TongVeBanRa %> Vé
                            </h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-warning text-dark shadow-sm">
                        <div class="card-body">
                            <h5>Tổng Hóa Đơn</h5>
                            <h3 class="fw-bold">
                                <%= tongQuan.TongHoaDon %> HĐ
                            </h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">Biểu Đồ Doanh Thu Theo Tháng (Năm Hiện Tại)</h5>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" height="100"></canvas>
                </div>
            </div>
        </div>

        <script>
            // prettier-ignore
            const rawData = JSON.parse('<%- doanhThuThang %>');
            // Khởi tạo mảng 12 tháng (mặc định = 0)
            const labels = ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6', 'Tháng 7', 'Tháng 8', 'Tháng 9', 'Tháng 10', 'Tháng 11', 'Tháng 12'];
            const dataDoanhThu = new Array(12).fill(0);

            // Đổ dữ liệu thật vào mảng
            rawData.forEach(item => {
                dataDoanhThu[item.Thang - 1] = item.DoanhThu;
            });

            // Vẽ biểu đồ
            const ctx = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: dataDoanhThu,
                        backgroundColor: 'rgba(220, 53, 69, 0.7)', // Màu đỏ hợp với theme rạp phim
                        borderColor: 'rgba(220, 53, 69, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        </script>
</body>

</html>