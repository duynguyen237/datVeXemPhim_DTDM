<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('../partials/head') %>
        <link rel="stylesheet" href="/css/admin_dashboard.css">
        <title>Quản lý Người Dùng - Admin</title>
</head>

<body>
    <%- include('../partials/admin_sidebar') %>
        <div class="main-content">
            <div class="top-nav">
                <h4 class="fw-bold mb-0">Hệ thống / <small class="text-muted">Người Dùng</small></h4>
            </div>
            <div class="card border-0 shadow-sm p-0 rounded-4 mt-4">
                <div class="table-responsive">
                    <table id="tableUsers" class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">STT</th>
                                <th>Thành viên</th>
                                <th>Liên hệ</th>
                                <th class="text-center">Vai Trò</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach((user, index)=> { %>
                                <tr>
                                    <td class="ps-4 fw-bold">
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <%= user.hoTen %>
                                            <div class="text-muted small">@<%= user.tenDangNhap %>
                                            </div>
                                    </td>
                                    <td>
                                        <%= user.email %><br>
                                            <small class="text-muted">
                                                <%= user.soDienThoai %>
                                            </small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge <%= user.vaiTro === 'admin' ? 'bg-danger' : 'bg-primary' %>">
                                            <%= user.vaiTro==='admin' ? 'Admin' : 'Khách hàng' %>
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-secondary" title="Sửa"><i
                                                class="bi bi-pencil"></i></button>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
</body>

</html>