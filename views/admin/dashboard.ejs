<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('../partials/head') %>
        <link rel="stylesheet" href="/css/admin_dashboard.css">
        <title>Bảng Điều Khiển - Admin Duy Movie</title>
</head>

<body>
    <%- include('../partials/admin_sidebar') %>

        <div class="main-content">
            <div class="top-nav">
