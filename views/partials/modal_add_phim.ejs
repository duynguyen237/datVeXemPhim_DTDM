<!-- Modal Thêm Phim Mới -->
<div class="modal fade" id="modalAddPhim" tabindex="-1" aria-labelledby="modalAddPhimLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold" id="modalAddPhimLabel">
                    <i class="bi bi-plus-circle me-2"></i>Thêm Phim Mới
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/phim/them" method="POST">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Tên Phim <span class="text-danger">*</span></label>
                            <input type="text" name="ten" class="form-control" placeholder="Nhập tên phim..." required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Thể Loại <span class="text-danger">*</span></label>
                            <select name="maTL" class="form-select" required>
                                <option value="">-- Chọn thể loại --</option>
                                <% theLoais.forEach(tl => { %>
                                    <option value="<%= tl._id %>"><%= tl.tenTheLoai %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Giới Hạn Tuổi</label>
                            <select name="tuoi" class="form-select">
                                <option value="P">P - Mọi đối tượng</option>
                                <option value="K">K - Có người lớn đi kèm</option>
                                <option value="T13">T13 - Trên 13 tuổi</option>
                                <option value="T16">T16 - Trên 16 tuổi</option>
                                <option value="T18">T18 - Trên 18 tuổi</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Thời Lượng (phút) <span class="text-danger">*</span></label>
                            <input type="number" name="thoiluong" class="form-control" placeholder="VD: 120" min="1" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Đạo Diễn</label>
                            <input type="text" name="daodien" class="form-control" placeholder="Tên đạo diễn">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Diễn Viên</label>
                            <input type="text" name="dienvien" class="form-control" placeholder="Các diễn viên chính (cách nhau bởi dấu phẩy)">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Link Trailer (YouTube)</label>
                            <input type="url" name="trailer" class="form-control" placeholder="https://youtube.com/...">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Link Hình Poster <span class="text-danger">*</span></label>
                            <input type="url" name="poster" class="form-control" placeholder="https://..." required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Link Hình Nền</label>
                            <input type="url" name="nen" class="form-control" placeholder="https://...">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Nội Dung / Mô Tả Phim</label>
                            <textarea name="noidung" class="form-control" rows="4" placeholder="Nhập mô tả nội dung phim..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger fw-bold px-4">
                        <i class="bi bi-save me-1"></i>Lưu Phim
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
